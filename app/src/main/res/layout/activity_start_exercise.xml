<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#009688"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NutritionAdvice">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Exercise"
        android:textAlignment="center"
        android:textSize="30sp"

        android:layout_marginTop="20dp"
        android:textColor="#752943"


        />

    <ImageView
        android:layout_width="367dp"
        android:layout_height="200dp"
        android:layout_margin="30dp"
        android:scaleType="centerCrop"
        android:src="@drawable/image7" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Starting an exercise routine is one of the most beneficial steps you can take for your physical and mental health, yet the best approach is to begin slowly and focus on consistency over intensity."
        android:textAlignment="center"
        android:textSize="20dp"

        android:layout_marginTop="20dp"
        android:textColor="#752943"


        />


</LinearLayout>