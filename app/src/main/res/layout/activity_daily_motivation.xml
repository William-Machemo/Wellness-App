<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#009688"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NutritionAdvice">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily Motivation"
        android:textAlignment="center"
        android:textSize="30sp"

        android:layout_marginTop="20dp"
        android:textColor="#752943"




        />
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:src="@drawable/image6"
        android:scaleType="centerCrop"
        android:layout_margin="30dp"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily motivation is the driving force that transforms positive intentions into immediate action, turning goals into reality. It acts as a necessary mental tonic, providing purpose and the stamina needed to overcome obstacles, break old habits, and build a fulfilling life. While motivation can fluctuate, staying consistent requires proactive habits—like reviewing your goals, visualizing success, or reading inspiring words—to keep your enthusiasm alive"
        android:textAlignment="center"
        android:textSize="20dp"

        android:layout_marginTop="20dp"
        android:textColor="#752943"




        />


</LinearLayout>