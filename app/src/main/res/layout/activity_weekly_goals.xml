<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#C36A6A"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HealthyRecipe">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weekly Goals"
        android:textAlignment="center"
        android:textSize="30sp"
        android:layout_marginTop="20dp"
        android:textColor="#10558C" />


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="217dp"
        android:layout_margin="20dp"
        android:scaleType="centerCrop"
        android:src="@drawable/image4" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weekly goals act as a crucial bridge between long-term aspirations and daily tasks, providing a structured 7-day roadmap to increase productivity and maintain focus. By breaking large projects into manageable bite-sized targets, weekly goals reduce procrastination and boost motivation."
        android:textAlignment="center"
        android:textSize="18sp"
        android:layout_margin="20dp"
        android:textColor="#10558C" />

</LinearLayout>