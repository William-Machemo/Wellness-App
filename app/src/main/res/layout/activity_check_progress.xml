<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#C36A6A"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HealthyRecipe">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Check Progress"
        android:textAlignment="center"
        android:textSize="30sp"
        android:layout_marginTop="20dp"
        android:textColor="#10558C" />

    <!-- Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_margin="20dp"
        android:scaleType="centerCrop"
        android:src="@drawable/image9" />

    <!-- Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking progress is a critical, ongoing process that involves measuring, monitoring, and evaluating activities against defined goals to ensure they remain on track. By regularly reviewing status updates using tools like checklists, KPIs, or performance metrics, individuals and teams can see how far they have come and determine how much work remains. This helps keep projects organized, reduces delays, and motivates progress."
        android:textAlignment="center"
        android:textSize="18sp"
        android:layout_margin="20dp"
        android:textColor="#000000" />

</LinearLayout>